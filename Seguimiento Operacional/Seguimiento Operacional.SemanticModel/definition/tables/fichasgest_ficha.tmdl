	/// Fecha de la actividad truncada al día (sin hora). Usada para relacionar con Calendario[Fecha].
	column FechaC = DATEVALUE('fichasgest_ficha'[fecha_actividad])
		formatString: General Date
		lineageTag: ac5c4806-9857-4dce-902d-bd283c7e6d8e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Nombre del mes de la actividad en texto. Usado para agrupaciones y medidas de pico mensual.
	column Mes =
			
			VAR m =
			    FORMAT ( [fecha_actividad], "MMMM", "es-ES" )
			RETURN
			    UPPER ( LEFT ( m, 1 ) ) &
			    RIGHT ( m, LEN ( m ) - 1 )
		lineageTag: 10479f54-b125-44c8-a9c8-d2b63dfa1ab1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

