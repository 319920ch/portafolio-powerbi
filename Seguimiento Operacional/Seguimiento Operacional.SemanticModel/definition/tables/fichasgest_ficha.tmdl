table fichasgest_ficha
	lineageTag: 9087e8f1-0cac-4861-863e-81eac266a11c

	/// Mes con mayor total de horas_utilizadas en fichas de servicio. Usa ALL sobre la columna Mes para ignorar filtros de contexto.
	measure 'Mes Pico' =
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('fichasgest_ficha'[Mes]),
			        'fichasgest_ficha'[Mes],
			        "Horas", SUM('fichasgest_ficha'[horas_utilizadas])
			    )
			RETURN
			MAXX(
			    FILTER(TablaMeses, [Horas] = MAXX(TablaMeses, [Horas])),
			    'fichasgest_ficha'[Mes]
			)
		displayFolder: Picos y Patrones
		lineageTag: 5015ce77-8927-4a33-b598-da2cc4bfbd91

	/// Total de horas utilizadas del mes pico de fichas, en valor numérico. Complementa la medida Mes Pico para mostrar la magnitud del pico.
	measure 'Hora Mes Pico' =
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('fichasgest_ficha'[Mes]),
			        'fichasgest_ficha'[Mes],
			        "Horas", SUM('fichasgest_ficha'[horas_utilizadas])
			    )
			RETURN
			MAXX(TablaMeses, [Horas])
		formatString: 0
		displayFolder: Picos y Patrones
		lineageTag: e58c1869-6d92-4eb9-aca5-4a2e69ec68b2

	/// Texto combinado: nombre del mes pico de fichas + total de horas entre paréntesis. Listo para tarjeta KPI de texto.
	measure 'KPI Mes Pico' = ```
			
			VAR Mes = [Mes Pico]
			VAR Horas = [Hora Mes Pico]
			RETURN
			Mes & " (" & FORMAT(Horas, "#,##0") & ")"
			
			```
		displayFolder: Picos y Patrones
		lineageTag: e468660f-79eb-45c3-969e-daf689200ee1

	/// Mes con menor total de horas_utilizadas en fichas de servicio. Útil para detectar períodos de baja actividad o meses sin registros.
	measure 'Mes Más Bajo' = ```
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('fichasgest_ficha'[Mes]),
			        'fichasgest_ficha'[Mes],
			        "Horas", SUM('fichasgest_ficha'[horas_utilizadas])
			    )
			RETURN
			MAXX(
			    FILTER(TablaMeses, [Horas] = MINX(TablaMeses, [Horas])),
			    'fichasgest_ficha'[Mes]
			)
			
			```
		displayFolder: Picos y Patrones
		lineageTag: 91aeb3c5-eb50-4f75-919e-4e4c2e54d1b2

	/// Total de horas utilizadas del mes con menor actividad, en valor numérico. Complementa la medida Mes Más Bajo.
	measure 'Horas Mes Bajo' =
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('fichasgest_ficha'[Mes]),
			        'fichasgest_ficha'[Mes],
			        "Horas", SUM('fichasgest_ficha'[horas_utilizadas])
			    )
			RETURN
			MINX(TablaMeses, [Horas])
		displayFolder: Picos y Patrones
		lineageTag: 87e0056a-418e-491d-a77f-86a7542ddfd7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Texto combinado: nombre del mes más bajo de fichas + total de horas entre paréntesis. Listo para tarjeta KPI de texto.
	measure 'KPI Mes Bajo' =
			
			VAR Mes = [Mes Más Bajo]
			VAR Horas = [Horas Mes Bajo]
			RETURN
			Mes & " (" & FORMAT(Horas, "#,##0") & ")"
		displayFolder: Picos y Patrones
		lineageTag: cdfd04fe-a1b4-464b-bff2-259f4964869d

