	/// Duración total del registro calculada como hora_fin - hora_inicio. Base para determinar si la jornada supera el límite ordinario.
	column Duracion =
			
			MOD(
			    'hora_inicio_fin'[hora_fin] - 'hora_inicio_fin'[hora_inicio],
			    1
			)
		dataType: dateTime
		formatString: Long Time
		displayFolder: Totales y Formato
		lineageTag: 3611e9ea-9bb9-4517-9f81-d479bb62dafa
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Clasifica cada registro como 'Normal', 'Extra' o 'Feriado' según el tipo de jornada. Usa Calendario[DiaSemanaNum] vía RELATED (6=Sábado, 7=Domingo) en lugar de nombre_dia para mayor robustez. Columna de segmentación clave para filtrar horas extras en visuals.
	column Extra =
			VAR DiaSemana = RELATED( Calendario[DiaSemanaNum] )
			VAR EsFeriado = RELATED( Calendario[EsFeriado] ) = 1
			RETURN
			SWITCH(
			    TRUE(),
			    EsFeriado, "Feriado",
			    DiaSemana IN { 6, 7 }, "Extra",
			    "Normal"
			)
		displayFolder: Clasificación de Horas
		lineageTag: 31dabf7d-4b19-49f0-8121-e22c9422aec1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Minutos del registro que corresponden a jornada ordinaria. Complemento de Minutos Extra para obtener el total de la actividad.
	column 'Minutos Normales' =
			
			VAR EsExtraDia =
			    'hora_inicio_fin'[Extra] IN {"Extra","Feriado"}
			VAR Inicio =
			    TIME(
			        HOUR('hora_inicio_fin'[hora_inicio]),
			        MINUTE('hora_inicio_fin'[hora_inicio]),
			        SECOND('hora_inicio_fin'[hora_inicio])
			    )
			
			VAR Fin =
			    TIME(
			        HOUR('hora_inicio_fin'[hora_fin]),
			        MINUTE('hora_inicio_fin'[hora_fin]),
			        SECOND('hora_inicio_fin'[hora_fin])
			    )
			
			VAR InicioLab = TIME(9,0,0)
			VAR FinLab    = TIME(18,0,0)
			
			VAR InicioEfectivo = MAX(Inicio, InicioLab)
			VAR FinEfectivo    = MIN(Fin, FinLab)
			
			VAR DuracionNormal =
			    IF(
			        FinEfectivo > InicioEfectivo,
			        FinEfectivo - InicioEfectivo,
			        0
			    )
			
			RETURN
			IF(
			    EsExtraDia,
			    0,
			    DuracionNormal
			)
		dataType: dateTime
		formatString: Long Time
		displayFolder: Totales y Formato
		lineageTag: deaebeeb-9765-49e6-bd52-aff9b074b19d
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Minutos fuera de la jornada ordinaria en formato DateTime. Usado como base para calcular MinutosExtraTotales y HorasExtraFormato.
	column 'Minutos Extra' =
			
			'hora_inicio_fin'[Duracion]
			-
			'hora_inicio_fin'[Minutos Normales]
		formatString: Long Time
		displayFolder: Totales y Formato
		lineageTag: da504af1-7acf-4c3e-a6a5-d240d8d33415
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Total de minutos extra en valor numérico decimal. Columna base sobre la que se construyen todas las medidas de horas extras del modelo.
	column MinutosExtraTotales = (HOUR([Minutos Extra]) * 60 + MINUTE([Minutos Extra]) + SECOND([Minutos Extra])/60)
		displayFolder: Totales y Formato
		lineageTag: dfa3322b-effb-4273-99f1-01ec497ad678
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Horas extras del registro en texto con formato HH:MM. Útil para mostrar el detalle por fila en tablas de detalle sin necesidad de una medida.
	column HorasExtraFormato =
			
			VAR TotalMin = [MinutosExtraTotales]
			VAR H = INT(TotalMin / 60)
			VAR M = MOD(TotalMin, 60)
			RETURN
			FORMAT(H, "00") & ":" & FORMAT(M, "00")
		displayFolder: Totales y Formato
		lineageTag: 1c1bccab-1b98-4e4c-921e-117e2fdd7589
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Hora de inicio del tramo extra temprano (antes del horario ordinario). Se usa para calcular las horas al 100% en jornadas que comienzan antes del límite.
	column 'Extra Temprano Inicio' =
			
			VAR InicioTrabajo = 'hora_inicio_fin'[hora_inicio]
			VAR InicioNormal  = TIME(9,0,0)
			VAR EsExtra       = 'hora_inicio_fin'[Extra] IN {"Extra","Feriado"}
			
			RETURN
			IF(
			    EsExtra
			        || InicioTrabajo < InicioNormal,
			    InicioTrabajo,
			    BLANK()
			)
		formatString: Long Time
		displayFolder: Franjas Horarias
		lineageTag: cfeb3db6-014b-4a85-940b-2a48aa183e47
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Hora de fin del tramo extra temprano. Junto con Extra Temprano Inicio determina la duración del tramo nocturno o anticipado con recargo al 100%.
	column 'Extra Temprano Fin' =
			
			VAR InicioTrabajo = 'hora_inicio_fin'[hora_inicio]
			VAR FinTrabajo    = 'hora_inicio_fin'[hora_fin]
			VAR TipoExtra     = 'hora_inicio_fin'[Extra]
			VAR InicioNormal  = TIME(9,0,0)
			
			RETURN
			IF(
			    TipoExtra IN {"Extra","Feriado"},
			        -- Si es Extra manual, siempre se toma el fin tal cual
			        FinTrabajo,
			    -- Si es Normal, se aplica la regla contra las 09:00
			    IF(
			        InicioTrabajo < InicioNormal,
			        MIN(FinTrabajo, InicioNormal),
			        BLANK()
			    )
			)
		formatString: Long Time
		displayFolder: Franjas Horarias
		lineageTag: 2750fc8d-9389-4fd7-83ad-fd6e6c9935f2
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Hora de inicio del tramo extra tarde (después del horario ordinario). Base del cálculo de horas al 50% en jornadas que se extienden fuera del horario normal.
	column 'Extra Tarde Inicio' =
			
			VAR InicioTrabajo = 'hora_inicio_fin'[hora_inicio]
			VAR TipoExtra = 'hora_inicio_fin'[Extra]
			VAR FinTrabajo =
			    IF(
			        'hora_inicio_fin'[hora_fin] < InicioTrabajo,
			        'hora_inicio_fin'[hora_fin] + 1,
			        'hora_inicio_fin'[hora_fin]
			    )
			
			VAR FinNormal = TIME(18,0,0)
			
			RETURN
			IF(
			    TipoExtra = "Extra",
			        -- Si es Extra manual, siempre se toma el fin tal cual
			        BLANK(),
			    -- Si es Normal, se aplica la regla contra las 09:00
			    IF(
			    FinTrabajo > FinNormal,
			    MAX(InicioTrabajo, FinNormal),
			    BLANK()
			    )
			)
		formatString: Long Time
		displayFolder: Franjas Horarias
		lineageTag: f237054a-3b01-43a4-b858-1d0f7256555e
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Hora de fin del tramo extra tarde. Junto con Extra Tarde Inicio determina la duración del tramo vespertino con recargo al 50%.
	column 'Extra Tarde Fin' =
			
			VAR InicioTrabajo = 'hora_inicio_fin'[hora_inicio]
			VAR TipoExtra = 'hora_inicio_fin'[Extra]
			VAR FinTrabajo =
			    IF(
			        'hora_inicio_fin'[hora_fin] < InicioTrabajo,
			        'hora_inicio_fin'[hora_fin] + 1,
			        'hora_inicio_fin'[hora_fin]
			    )
			
			VAR FinNormal = TIME(18,0,0)
			
			RETURN
			IF(
			     TipoExtra = "Extra",
			        -- Si es Extra manual, siempre se toma el fin tal cual
			        BLANK(),
			        if(
			    FinTrabajo > FinNormal,
			    FinTrabajo,
			    BLANK())
			)
		formatString: Long Time
		displayFolder: Franjas Horarias
		lineageTag: 8fee07e0-f3a3-4902-9b7d-98bf3e0915b2
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	/// Clasifica el registro como 'Hora al 50%' o 'Hora al 100%' según el tramo horario. Usada como filtro en las medidas Total Minutos Extra HHMMSS 50% y 100%.
	column Hora = ```
			
			VAR TipoExtra = 'hora_inicio_fin'[Extra]
			
			VAR ExtraTardeInicio = hora_inicio_fin[Extra Tarde Inicio]
			VAR ExtraTardeFinRaw = hora_inicio_fin[Extra Tarde Fin]
			
			VAR ExtraTardeFin =
			    IF(
			        NOT ISBLANK(ExtraTardeInicio)
			            && ExtraTardeFinRaw < ExtraTardeInicio,
			        ExtraTardeFinRaw + 1,
			        ExtraTardeFinRaw
			    )
			VAR ExtraTempranoInicio = hora_inicio_fin[Extra Temprano Inicio]
			VAR ExtraTempranoFinRaw = hora_inicio_fin[Extra Temprano Fin]
			
			VAR ExtraTempranoFin =
			    IF(
			        NOT ISBLANK(ExtraTempranoInicio)
			            && ExtraTempranoFinRaw < ExtraTempranoInicio,
			        ExtraTempranoFinRaw + 1,
			        ExtraTempranoFinRaw
			    )
			
			
			VAR Hay50 =
			    NOT ISBLANK(ExtraTardeInicio)
			        && NOT ISBLANK(ExtraTardeFin)
			        && ExtraTardeFin > ExtraTardeInicio
			VAR Hay100 =
			    NOT ISBLANK(ExtraTempranoInicio)
			        && NOT ISBLANK(ExtraTempranoFin)
			        && ExtraTempranoFin > ExtraTempranoInicio
			
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    -- 🔴 PRIORIDAD 1: Si es Extra manual
			    TipoExtra IN {"Extra","Feriado"}, "Hora al 100%",
			
			    -- 🟡 Evaluación normal,
			    Hay100, "Hora al 100%",
			    Hay50, "Hora al 50%",    
			    
			
			
			    ""
			)
			```
		displayFolder: Clasificación de Horas
		lineageTag: 46d2c2b5-8194-4399-b43c-b67d88ddfe1c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Minutos extra con recargo al 50%, correspondientes al tramo Extra Tarde (fuera de horario pero en jornada normal). Base de las medidas HorasExtra50_h_mm.
	column Minutos50 =
			
			VAR Inicio =
			    TIME(
			        HOUR(hora_inicio_fin[hora_inicio]),
			        MINUTE(hora_inicio_fin[hora_inicio]),
			        SECOND(hora_inicio_fin[hora_inicio])
			    )
			
			VAR FinOriginal =
			    TIME(
			        HOUR(hora_inicio_fin[hora_fin]),
			        MINUTE(hora_inicio_fin[hora_fin]),
			        SECOND(hora_inicio_fin[hora_fin])
			    )
			
			VAR Fin =
			    IF(FinOriginal < Inicio, FinOriginal + 1, FinOriginal)
			
			VAR Extra = hora_inicio_fin[Extra]
			
			VAR Inicio50 = TIME(18,0,0)
			VAR Fin50 = TIME(23,59,59)
			
			VAR InicioCalc = MAX(Inicio, Inicio50)
			VAR FinCalc = MIN(Fin, Fin50)
			
			RETURN
			IF(
			    FinCalc > InicioCalc && NOT ( Extra IN { "Feriado", "Extra" } ),
			    (FinCalc - InicioCalc) * 1440,
			    0
			)
		displayFolder: Totales y Formato
		lineageTag: 00faf570-44c9-4b93-adde-91d242fab6e5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Minutos extra con recargo al 100%, correspondientes a jornadas Extra, Feriado o tramo Extra Temprano. Base de las medidas HorasExtra100_h_mm.
	column Minutos100 =
			
			VAR Inicio =
			    TIME(
			        HOUR(hora_inicio_fin[hora_inicio]),
			        MINUTE(hora_inicio_fin[hora_inicio]),
			        SECOND(hora_inicio_fin[hora_inicio])
			    )
			
			VAR Fin =
			    TIME(
			        HOUR(hora_inicio_fin[hora_fin]),
			        MINUTE(hora_inicio_fin[hora_fin]),
			        SECOND(hora_inicio_fin[hora_fin])
			    )
			
			VAR Extra = hora_inicio_fin[Extra]
			
			-- Rango 100
			VAR Inicio100 = TIME(0,0,0)
			VAR Fin100 = TIME(9,0,0)
			
			-- Cálculo solo para rango 100
			VAR InicioCalc = MAX(Inicio, Inicio100)
			VAR FinCalc = MIN(Fin, Fin100)
			
			RETURN
			IF (
			    Extra IN { "Feriado", "Extra" },
			    -- En feriado se cuentan TODOS los minutos
			    MAX( (Fin - Inicio) * 1440, 0 ),
			    -- Caso normal: solo de 00:00 a 09:00
			    IF (
			        FinCalc > InicioCalc,
			        (FinCalc - InicioCalc) * 1440,
			        0
			    )
			)
		displayFolder: Totales y Formato
		lineageTag: 6add59dc-a3c1-4607-b662-1c8af2a722b7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

