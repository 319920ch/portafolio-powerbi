table hora_inicio_fin
	lineageTag: 51ba3187-7ccf-4af6-ba08-49c3373cee82

	/// Total global de horas extras en formato HH:MM:SS. Calculado desde la columna Minutos Extra. Usar en tarjetas KPI de resumen general.
	measure 'Total Minutos Extra HHMMSS' = ```
			
			VAR TotalSegundos =
			    SUMX(
			        'hora_inicio_fin',
			        HOUR('hora_inicio_fin'[Minutos Extra]) * 3600 +
			        MINUTE('hora_inicio_fin'[Minutos Extra]) * 60 
			    )
			
			VAR Horas = INT(TotalSegundos / 3600)
			VAR Minutos = INT(MOD(TotalSegundos, 3600) / 60)
			
			RETURN
			FORMAT(Horas,"00") & ":" &
			FORMAT(Minutos,"00") 
			```
		displayFolder: Totales y Formato
		lineageTag: 4f649887-f795-4f34-936c-696c09aaef8d

	/// Cuenta el número de registros con hora de inicio registrada. Útil para medir la cantidad de actividades en un período, independiente de las horas extras.
	measure 'Conteo inicio' = COUNT(hora_inicio_fin[hora_inicio])
		formatString: 0
		displayFolder: Picos y Patrones
		lineageTag: a971f4cc-eae2-4417-822a-c927efaf048c

	/// Hora del día (HH:MM) con mayor concentración de registros de inicio de actividad. Identifica el horario más frecuente de inicio de trabajo extra.
	measure 'Hora Pico Inicio' = ```
			
			VAR TablaHoras =
			    SUMMARIZE(
			        ALL('hora_inicio_fin'[hora_inicio]),
			        'hora_inicio_fin'[hora_inicio],
			        "Eventos", COUNT('hora_inicio_fin'[hora_inicio])
			    )
			VAR MaxEventos =
			    MAXX(TablaHoras, [Eventos])
			RETURN
			MAXX(
			    FILTER(TablaHoras, [Eventos] = MaxEventos),
			    FORMAT('hora_inicio_fin'[hora_inicio], "hh:mm")
			)
			
			```
		displayFolder: Picos y Patrones
		lineageTag: 4322d4d1-e037-4ec3-be62-c3550fc7af65

	/// Día de la semana con más registros de hora de inicio. Permite identificar qué día concentra mayor actividad extra.
	measure 'Día Pico Inicio' =
			
			VAR TablaDias =
			    SUMMARIZE(
			        ALL('Calendario'[DiaSemana]),
			        'Calendario'[DiaSemana],
			        "Horas", COUNT('hora_inicio_fin'[hora_inicio])
			    )
			VAR MaxHoras =
			    MAXX(TablaDias, [Horas])
			RETURN
			MAXX(
			    FILTER(TablaDias, [Horas] = MaxHoras),
			    'Calendario'[DiaSemana]
			)
		displayFolder: Picos y Patrones
		lineageTag: 8273590a-e673-4cc0-8f33-5f0409430819

	/// Subtotal de horas extras al 50% en formato HH:MM:SS. Filtra registros donde Hora = 'Hora al 50%'. Complemento de la medida al 100%.
	measure 'Total Minutos Extra HHMMSS 50%' =
			
			VAR TotalSegundos =
			    SUMX(
			        FILTER(
			            'hora_inicio_fin',
			            'hora_inicio_fin'[Hora] = "Hora al 50%"
			        ),
			        HOUR('hora_inicio_fin'[Minutos Extra]) * 3600 +
			        MINUTE('hora_inicio_fin'[Minutos Extra]) * 60 +
			        SECOND('hora_inicio_fin'[Minutos Extra])
			    )
			
			VAR Horas = INT(TotalSegundos / 3600)
			VAR Minutos = INT(MOD(TotalSegundos, 3600) / 60)
			VAR Segundos = INT(MOD(TotalSegundos, 60))
			
			RETURN
			FORMAT(Horas,"00") & ":" &
			FORMAT(Minutos,"00") & ":" &
			FORMAT(Segundos,"00")
		displayFolder: Totales y Formato
		lineageTag: 6ca5b4f9-ba5f-458f-93d1-cec7d1a6a3fc

	/// Subtotal de horas extras al 100% en formato HH:MM:SS. Filtra registros donde Hora = 'Hora al 100%'. Aplica a feriados y turnos nocturnos.
	measure 'Total Minutos Extra HHMMSS 100%' =
			
			VAR TotalSegundos =
			    SUMX(
			        FILTER(
			            'hora_inicio_fin',
			            'hora_inicio_fin'[Hora] = "Hora al 100%"
			        ),
			        HOUR('hora_inicio_fin'[Minutos Extra]) * 3600 +
			        MINUTE('hora_inicio_fin'[Minutos Extra]) * 60 +
			        SECOND('hora_inicio_fin'[Minutos Extra])
			    )
			
			VAR Horas = INT(TotalSegundos / 3600)
			VAR Minutos = INT(MOD(TotalSegundos, 3600) / 60)
			VAR Segundos = INT(MOD(TotalSegundos, 60))
			
			RETURN
			FORMAT(Horas,"00") & ":" &
			FORMAT(Minutos,"00") & ":" &
			FORMAT(Segundos,"00")
		displayFolder: Totales y Formato
		lineageTag: 8a2ca405-f32d-460d-83fe-c5764afd9dd2

	/// Nombre del mes con mayor acumulado de MinutosExtraTotales. Considera todos los meses disponibles ignorando filtros de fecha. Ideal para tarjeta KPI.
	measure 'Mes Pico Extra' =
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('Calendario'[Mes]),
			        'Calendario'[Mes],
			        "Horas", SUM('hora_inicio_fin'[MinutosExtraTotales])
			    )
			RETURN
			MAXX(
			    FILTER(TablaMeses, [Horas] = MAXX(TablaMeses, [Horas])),
			    'Calendario'[Mes]
			)
		displayFolder: Picos y Patrones
		lineageTag: b7aaaedc-7367-4862-b639-780ecb3259c7

	/// Total de horas extras del mes pico en formato HH:MM. Complementa la medida Mes Pico Extra para mostrar la magnitud del pico.
	measure 'Hora Mes Pico Extra' = ```
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL('Calendario'[Mes]),
			        'Calendario'[Mes],
			        "MinutosMes", SUM('hora_inicio_fin'[MinutosExtraTotales])
			    )
			
			VAR MaxMinutos =
			    MAXX(TablaMeses, [MinutosMes])
			
			VAR TotalSegundos = MaxMinutos * 60
			
			VAR Horas = INT(TotalSegundos / 3600)
			VAR Minutos = INT(MOD(TotalSegundos, 3600) / 60)
			VAR Segundos = INT(MOD(TotalSegundos, 60))
			
			RETURN
			FORMAT(Horas,"00") & ":" &
			FORMAT(Minutos,"00") 
			```
		displayFolder: Picos y Patrones
		lineageTag: c37ae219-7f87-44b4-9e6e-cfab9ef32131

	/// Texto combinado: nombre del mes pico + total de horas entre paréntesis. Ejemplo: 'Marzo (127)'. Listo para usar en una tarjeta KPI de texto.
	measure 'KPI Mes Pico Extra' =
			
			VAR Mes = [Mes Pico Extra]
			VAR Horas = [Hora Mes Pico Extra]
			RETURN
			Mes & " (" & FORMAT(Horas, "#,##0") & ")"
		displayFolder: Picos y Patrones
		lineageTag: ed278efc-6b9b-4568-b401-d844c7f59cb6

	/// Nombre de la empresa (fichasgest_cliente) con mayor acumulado de horas extras. Usa la relación cliente_id para obtener el nombre desde la tabla de clientes.
	measure 'Cliente Pico Extra' =
			
			VAR TablaClientes =
			    SUMMARIZE(
			        ALL('hora_inicio_fin'[cliente_id]),
			        'hora_inicio_fin'[cliente_id],
			        "MinutosCliente", SUM('hora_inicio_fin'[MinutosExtraTotales])
			    )
			
			VAR MaxMinutos =
			    MAXX(TablaClientes, [MinutosCliente])
			
			VAR ClienteTop =
			    MAXX(
			        FILTER(TablaClientes, [MinutosCliente] = MaxMinutos),
			        'hora_inicio_fin'[cliente_id]
			    )
			
			RETURN
			CALCULATE(
			    SELECTEDVALUE('fichasgest_cliente'[empresa]),
			    'fichasgest_cliente'[id] = ClienteTop
			)
		displayFolder: Clientes
		lineageTag: 0eb8d9a1-e937-47cb-9e33-ab8e7324b6f8

	/// Total de horas extras del cliente con mayor acumulado, en formato HH:MM. Complementa la medida Cliente Pico Extra para mostrar la magnitud.
	measure 'Hora Cliente Pico Extra' =
			
			VAR TablaMeses =
			    SUMMARIZE(
			        ALL(hora_inicio_fin[cliente_id]),
			        hora_inicio_fin[cliente_id],
			        "MinutosMes", SUM('hora_inicio_fin'[MinutosExtraTotales])
			    )
			
			VAR MaxMinutos =
			    MAXX(TablaMeses, [MinutosMes])
			
			VAR TotalSegundos = MaxMinutos * 60
			
			VAR Horas = INT(TotalSegundos / 3600)
			VAR Minutos = INT(MOD(TotalSegundos, 3600) / 60)
			VAR Segundos = INT(MOD(TotalSegundos, 60))
			
			RETURN
			FORMAT(Horas,"00") & ":" &
			FORMAT(Minutos,"00")
		displayFolder: Clientes
		lineageTag: efb4d8e6-6d23-44c2-9d1c-3baba4e1a02c

	/// Texto combinado: nombre del cliente pico + total de horas entre paréntesis. Listo para tarjeta KPI de texto. Ejemplo: 'Empresa ABC (98)'.
	measure 'KPI Cliente Pico Extra' =
			
			VAR Mes = [Cliente Pico Extra]
			VAR Horas = [Hora Cliente Pico Extra]
			RETURN
			Mes & " (" & FORMAT(Horas, "#,##0") & ")"
		displayFolder: Clientes
		lineageTag: b4438fe4-af7e-4b3a-a4b1-3ca473ccd856

	/// Total de horas extras en formato H:MM. Suma MinutosExtraTotales y convierte a horas y minutos. Usar en tablas y tarjetas de resumen.
	measure HorasExtra_h_mm = ```
			
			VAR TotalMinutos =
			    COALESCE(
			        SUM ( 'hora_inicio_fin'[MinutosExtraTotales] ),
			        0
			    )
			VAR Horas =
			    INT ( TotalMinutos / 60 )
			VAR Minutos =
			    MOD ( TotalMinutos, 60 )
			RETURN
			    FORMAT ( Horas, "0" ) & ":" & FORMAT ( Minutos, "00" )
			
			
			```
		displayFolder: Totales y Formato
		lineageTag: bc0250e3-5f3d-43ec-8a4b-8abc3627f8a0

	/// Clasifica un registro como 'Hora al 100%' si el tipo de jornada es Extra o Feriado, o si tiene Extra Temprano con duración válida. Usada como columna calculada de apoyo.
	measure 'Hora 100' =
			
			VAR TipoExtra = SELECTEDVALUE(hora_inicio_fin[Extra])
			
			VAR ExtraTempranoInicio = SELECTEDVALUE(hora_inicio_fin[Extra Temprano Inicio])
			VAR ExtraTempranoFinRaw = SELECTEDVALUE(hora_inicio_fin[Extra Temprano Fin])
			
			VAR ExtraTempranoFin =
			    IF(
			        NOT ISBLANK(ExtraTempranoInicio)
			        && ExtraTempranoFinRaw < ExtraTempranoInicio,
			        ExtraTempranoFinRaw + 1,
			        ExtraTempranoFinRaw
			    )
			
			VAR Hay100 =
			    NOT ISBLANK(ExtraTempranoInicio)
			    && NOT ISBLANK(ExtraTempranoFin)
			    && ExtraTempranoFin > ExtraTempranoInicio
			
			RETURN
			IF(
			    TipoExtra IN {"Extra","Feriado"} || Hay100,
			    "Hora al 100%",
			    ""
			)
		displayFolder: Clasificación de Horas
		lineageTag: d3ff136c-bfc4-4b04-85ba-fbc3f52a9290

	/// Clasifica un registro como 'Hora al 50%' si tiene Extra Tarde con duración válida y no es jornada Extra o Feriado. Usada como columna calculada de apoyo en tablas de detalle.
	measure 'Hora 50' =
			
			VAR TipoExtra = SELECTEDVALUE(hora_inicio_fin[Extra])
			
			VAR ExtraTardeInicio = SELECTEDVALUE(hora_inicio_fin[Extra Tarde Inicio])
			VAR ExtraTardeFinRaw = SELECTEDVALUE(hora_inicio_fin[Extra Tarde Fin])
			
			VAR ExtraTardeFin =
			    IF(
			        NOT ISBLANK(ExtraTardeInicio)
			        && ExtraTardeFinRaw < ExtraTardeInicio,
			        ExtraTardeFinRaw + 1,
			        ExtraTardeFinRaw
			    )
			
			VAR Hay50 =
			    NOT ISBLANK(ExtraTardeInicio)
			    && NOT ISBLANK(ExtraTardeFin)
			    && ExtraTardeFin > ExtraTardeInicio
			
			RETURN
			IF(
			    NOT(TipoExtra IN {"Extra","Feriado"}) && Hay50,
			    "Hora al 50%",
			    ""
			)
		displayFolder: Clasificación de Horas
		lineageTag: 72f39a12-e123-425f-aed1-ba8bd64c617e

	/// Total de horas extras al 50% en formato HH:MM. Basado en columna Minutos50. Usar junto a HorasExtra100_h_mm para desglosar el tipo de recargo.
	measure HorasExtra50_h_mm = ```
			
			VAR TotalMinutos =
			    COALESCE(
			        ROUND(SUM('hora_inicio_fin'[Minutos50]),0),
			        0
			    )
			VAR Horas =
			    INT(TotalMinutos / 60)
			VAR Minutos =
			    MOD(TotalMinutos, 60)
			
			RETURN
			FORMAT(Horas,"00") & ":" & FORMAT(Minutos,"00") 
			```
		displayFolder: Totales y Formato
		lineageTag: b9551df0-6070-4ce2-8d4a-8f07ad49c9cc

	/// Total de horas extras al 100% en formato HH:MM. Basado en columna Minutos100. Aplica a jornadas en feriados o turnos nocturnos.
	measure HorasExtra100_h_mm = ```
			
			VAR TotalMinutos =
			    COALESCE(
			        ROUND(SUM('hora_inicio_fin'[Minutos100]),0),
			        0
			    )
			VAR Horas =
			    INT(TotalMinutos / 60)
			VAR Minutos =
			    MOD(TotalMinutos, 60)
			
			RETURN
			FORMAT(Horas,"00") & ":" & FORMAT(Minutos,"00") 
			```
		displayFolder: Totales y Formato
		lineageTag: 9bf14c98-c390-4270-a1f3-f8edfd29da49

	/// Posición del consultor por total de minutos extra (1 = más horas). Muestra BLANK en la fila de totales. Usa auth_user[Consultor] via ingeniero_id.
	measure 'Ranking Consultor Horas Extra' =
			IF(
			    ISINSCOPE( auth_user[Consultor] ),
			    RANKX(
			        ALLSELECTED( auth_user[Consultor] ),
			        CALCULATE(
			            COALESCE( SUM( hora_inicio_fin[MinutosExtraTotales] ), 0 )
			        ),
			        ,
			        DESC,
			        DENSE
			    ),
			    BLANK()
			)
		formatString: 0
		displayFolder: Análisis Horas Extra
		lineageTag: 9b6f80da-d787-487b-ad11-f9bdf8c5227b

	/// Nombre del consultor con mayor acumulado de horas extras en el período filtrado. Ideal para tarjeta KPI. Usa auth_user[Consultor] via ingeniero_id.
	measure 'Top Consultor Horas Extra' =
			VAR Resumen =
			    ADDCOLUMNS(
			        ALLSELECTED( auth_user[Consultor] ),
			        "TotalMin",
			        CALCULATE(
			            COALESCE( SUM( hora_inicio_fin[MinutosExtraTotales] ), 0 )
			        )
			    )
			VAR MaxMin = MAXX( Resumen, [TotalMin] )
			RETURN
			    MINX(
			        FILTER( Resumen, [TotalMin] = MaxMin ),
			        auth_user[Consultor]
			    )
		displayFolder: Análisis Horas Extra
		lineageTag: 3a9b9d46-05d8-48d9-8a77-1dae9e1f5c73

	/// Porcentaje de horas extras de cada consultor sobre el total del período seleccionado. Usa auth_user[Consultor] vía ingeniero_id.
	measure '% Horas Extra del Total' =
			VAR TotalConsultor =
			    COALESCE( SUM( hora_inicio_fin[MinutosExtraTotales] ), 0 )
			VAR TotalGeneral =
			    CALCULATE(
			        COALESCE( SUM( hora_inicio_fin[MinutosExtraTotales] ), 0 ),
			        ALLSELECTED( auth_user[Consultor] )
			    )
			RETURN
			    DIVIDE( TotalConsultor, TotalGeneral, 0 )
		formatString: 0.00%
		displayFolder: Análisis Horas Extra
		lineageTag: bdddf431-690f-4f40-8e80-63ceb5565fe7

	/// Total de horas extras al 50% en valor decimal. Usar como valor numérico en gráficos (eje Y, barras apiladas). Complemento de Horas Extra 100 (h).
	measure 'Horas Extra 50 (h)' = DIVIDE( COALESCE( SUM( hora_inicio_fin[Minutos50] ), 0 ), 60 )
		formatString: 0.0
		displayFolder: Totales y Formato
		lineageTag: db1f4e11-f5e2-4079-a7a8-415c561120aa

	/// Total de horas extras al 100% en valor decimal. Usar como valor numérico en gráficos (eje Y, barras apiladas). Complemento de Horas Extra 50 (h).
	measure 'Horas Extra 100 (h)' = DIVIDE( COALESCE( SUM( hora_inicio_fin[Minutos100] ), 0 ), 60 )
		formatString: 0.0
		displayFolder: Totales y Formato
		lineageTag: e04435a6-420c-4555-9335-34ddebac64e9

	/// Etiqueta de datos en formato H:MM para el segmento de horas al 50%. Devuelve BLANK cuando es 0 para no mostrar etiquetas vacías en el gráfico. Usar en el campo Etiquetas de datos del visual de barras apiladas.
	measure 'Etiqueta Horas 50 (h:mm)' =
			VAR TotalMinutos = COALESCE( ROUND( SUM( hora_inicio_fin[Minutos50] ), 0 ), 0 )
			VAR Horas = INT( TotalMinutos / 60 )
			VAR Minutos = MOD( TotalMinutos, 60 )
			RETURN
			IF(
			    TotalMinutos = 0,
			    BLANK(),
			    FORMAT( Horas, "0" ) & ":" & FORMAT( Minutos, "00" )
			)
		displayFolder: Totales y Formato
		lineageTag: 3078961a-61a7-49dc-9f85-571ccb53536b

	/// Etiqueta de datos en formato H:MM para el segmento de horas al 100%. Devuelve BLANK cuando es 0 para no mostrar etiquetas vacías en el gráfico. Usar en el campo Etiquetas de datos del visual de barras apiladas.
	measure 'Etiqueta Horas 100 (h:mm)' =
			VAR TotalMinutos = COALESCE( ROUND( SUM( hora_inicio_fin[Minutos100] ), 0 ), 0 )
			VAR Horas = INT( TotalMinutos / 60 )
			VAR Minutos = MOD( TotalMinutos, 60 )
			RETURN
			IF(
			    TotalMinutos = 0,
			    BLANK(),
			    FORMAT( Horas, "0" ) & ":" & FORMAT( Minutos, "00" )
			)
		displayFolder: Totales y Formato
		lineageTag: c81c69c5-a915-4f55-8032-25e7d2ae28aa

	/// Etiqueta del total apilado en formato H:MM (50% + 100% combinados). Devuelve BLANK cuando es 0. Usar como etiqueta del total de la pila en el gráfico de barras apiladas.
	measure 'Etiqueta Total Horas Extra (h:mm)' =
			VAR TotalMinutos = COALESCE( ROUND( SUM( hora_inicio_fin[MinutosExtraTotales] ), 0 ), 0 )
			VAR Horas = INT( TotalMinutos / 60 )
			VAR Minutos = MOD( TotalMinutos, 60 )
			RETURN
			IF(
			    TotalMinutos = 0,
			    BLANK(),
			    FORMAT( Horas, "0" ) & ":" & FORMAT( Minutos, "00" )
			)
		displayFolder: Totales y Formato
		lineageTag: eb641dc1-e87d-4d4b-9571-d7500a18040f

