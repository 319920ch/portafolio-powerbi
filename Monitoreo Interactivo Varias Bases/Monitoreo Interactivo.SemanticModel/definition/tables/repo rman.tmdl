	/// Tiempo de ejecución del respaldo convertido a minutos desde tiempoejecucion. Base para cálculos de velocidad y RTO.
	column TiempoMinutos = 'repo rman'[tiempoejecucion]/60
		lineageTag: 8cf0008e-4f3c-42c6-ae82-939fa8f9b3f5
		summarizeBy: none

		annotation SummarizationSetBy = User

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Tamaño del respaldo convertido a Gigabytes desde tamanomb (Megabytes). Usado en medidas de velocidad y RTO.
	column tamanoGB = 'repo rman'[tamanomb]/1024
		lineageTag: da45c1fe-eb27-481f-b5a5-d62a6d878e06
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Clasificación del tipo de respaldo para el cálculo de RTO mensual: 'FULL_BASE' para el primer FULL del mes, 'INCREMENTAL' para los demás. Determina la estrategia de recuperación.
	column TipoBackup_Mensual = ```
			
			VAR maxMes =
			    CALCULATE(
			        MAX('repo rman'[tamanoGB]),
			        ALLEXCEPT(
			            'repo rman',
			            'repo rman'[sid],
			            'repo rman'[AnioMes]
			        )
			    )
			RETURN
			IF(
			    'repo rman'[tamanoGB] >= maxMes * 0.7,
			    "FULL_BASE",
			    "INCREMENTAL"
			)
			
			
			```
		lineageTag: d3744eab-e4ed-472d-a49e-048c3fd5daf6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Clave numérica de año-mes en formato AAAAMM derivada de fechainicio. Usada para agrupaciones y comparaciones mensuales.
	column AnioMes = ```
			
			YEAR('repo rman'[fechainicio]) * 100
			+ MONTH('repo rman'[fechainicio])
			
			```
		formatString: 0
		lineageTag: 2af90e91-b474-4c19-af6e-88301de17093
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Fecha truncada al día (sin hora) derivada de fechainicio. Usada para relacionar con Calendario1[Fecha] en medidas como Respaldos por Día.
	column FechaC = DATEVALUE('repo rman'[fechainicio])
		formatString: General Date
		lineageTag: b3129de5-8d11-44aa-b5c7-553d82d6f412
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'repo rman' = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database("192.168.2.51", "repo"),
				    repo_rman = Source{[Schema="repo",Item="rman"]}[Data]
				in
				    repo_rman

	annotation PBI_ResultType = Exception

