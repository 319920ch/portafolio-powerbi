table 'repo uptime_bdd_events'
	lineageTag: 3825a2a3-6a11-4014-afd6-71e2dc541b3e

	/// Cuenta el total de eventos donde el servicio estuvo caído (arriba = 0). Se usa para cuantificar incidencias de indisponibilidad en el período filtrado.
	measure 'Eventos DOWN' =
			
			CALCULATE(
			    COUNTROWS('repo uptime_bdd_events'),
			    'repo uptime_bdd_events'[arriba] = 0
			)
		formatString: 0
		lineageTag: f626d081-1bd5-4ae6-937d-28fd24e00ea9

	/// Calcula la duración total en segundos de cada evento DOWN, acotada al fin del mes en curso. Usa la columna FechaFin_Gantt directamente y aplica el límite de fin de mes como VAR externa al SUMX para mayor claridad y consistencia.
	measure 'DuracionSegundos (Medida)' = ```
			
			VAR Hoy = TODAY()
			VAR FinMes =
			    EOMONTH ( DATE ( YEAR ( Hoy ), MONTH ( Hoy ), 1 ), 0 ) + TIME ( 23, 59, 59 )
			
			RETURN
			SUMX(
			    'repo uptime_bdd_events',
			    VAR Inicio = 'repo uptime_bdd_events'[hora_evento]
			    VAR FinReal = 'repo uptime_bdd_events'[FechaFin_Gantt]
			    VAR Fin = IF( FinReal > FinMes, FinMes, FinReal )
			    RETURN
			    IF(
			        NOT ISBLANK( Fin ) && Fin > Inicio,
			        DATEDIFF( Inicio, Fin, SECOND ),
			        0
			    )
			)
			
			```
		formatString: 0
		lineageTag: cdf100ec-9b2d-40aa-a854-add7d376ad3e

	/// Convierte la duración total de eventos DOWN a días decimales (DuracionSegundos / 86400). Útil para cálculos de disponibilidad y visualizaciones de Gantt.
	measure 'DuracionTiempo (Medida)' = ```
			
			DIVIDE( [DuracionSegundos (Medida)], 86400 )
			
			```
		lineageTag: b9ae8901-b6f5-4a55-97b2-7e7a37cbf456

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Formatea la duración total de eventos DOWN en texto legible con el formato 'Xd HH:MM:SS'. Se basa en DuracionSegundos (Medida) y retorna '0d 00:00:00' si no hay duración registrada.
	measure DuracionTotal_DD_HHMMSS = ```
			
			VAR TotalSegundos = [DuracionSegundos (Medida)]
			VAR Dias =
			    INT( TotalSegundos / 86400 )
			VAR Horas =
			    INT( MOD( TotalSegundos, 86400 ) / 3600 )
			VAR Minutos =
			    INT( MOD( TotalSegundos, 3600 ) / 60 )
			VAR Segundos =
			    MOD( TotalSegundos, 60 )
			RETURN
			IF(
			    TotalSegundos > 0,
			    FORMAT(Dias, "0") & "d "
			        & FORMAT(Horas, "00") & ":"
			        & FORMAT(Minutos, "00") & ":"
			        & FORMAT(Segundos, "00"),
			    "0d 00:00:00"
			)
			
			
			
			```
		lineageTag: 21d7745f-b33f-45a2-a313-23b37fbbd049

	/// Devuelve la fecha de fin efectiva de un evento para el Gantt mensual. Si el evento se extiende más allá del fin del mes actual, lo recorta al último instante del mes (23:59:59). Garantiza que el Gantt no muestre eventos fuera del período del informe.
	measure FechaFin_Gantt_Mes = ```
			
			VAR FinReal =
			    MAX ( 'repo uptime_bdd_events'[FechaFin_Gantt] )
			
			VAR Hoy = TODAY()
			
			VAR InicioMes =
			    DATE ( YEAR ( Hoy ), MONTH ( Hoy ), 1 )
			
			VAR FinMes =
			    EOMONTH ( InicioMes, 0 ) + TIME ( 23, 59, 59 )
			
			RETURN
			IF (
			    FinReal > FinMes,
			    FinMes,
			    FinReal
			)
			
			```
		formatString: General Date
		lineageTag: 3b047c5b-d9c2-4ddf-b9f1-a579e1d70121

	/// Indicador (1/0) que determina si un evento pertenece al mes en curso. Retorna 1 si el inicio del evento es anterior o igual al último día del mes actual. Se usa para filtrar eventos vigentes en el informe mensual.
	measure Evento_Activo_Mes = ```
			
			VAR InicioEvento =
			    MIN ( 'repo uptime_bdd_events'[hora_evento] )
			
			VAR Hoy = TODAY()
			
			VAR InicioMes =
			    DATE ( YEAR ( Hoy ), MONTH ( Hoy ), 1 )
			
			VAR FinMes =
			    EOMONTH ( InicioMes, 0 )
			
			RETURN
			IF (
			    InicioEvento <= FinMes,
			    1,
			    0
			)
			
			```
		formatString: 0
		lineageTag: c12bf501-57d4-4121-9970-9f8b30d8ea14

