	/// Fecha y hora del siguiente evento registrado para el mismo servidor (ip+sid), ordenado por hora_evento. Usada para calcular la duracíon de cada evento hasta que el estado cambió.
	column FechaSiguienteEvento = ```
			
			VAR sidActual = 'repo uptime_bdd_events'[sid]
			VAR fechaActual = 'repo uptime_bdd_events'[hora_evento]
			RETURN
			CALCULATE(
			    MIN('repo uptime_bdd_events'[hora_evento]),
			    FILTER(
			        ALL('repo uptime_bdd_events'),
			        'repo uptime_bdd_events'[sid] = sidActual &&
			        'repo uptime_bdd_events'[hora_evento] > fechaActual
			    )
			)
			
			```
		formatString: General Date
		lineageTag: 54e3411b-640b-4cff-bb1a-977a7b50627d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Duración del evento formateada en texto HH:MM:SS, calculada entre hora_evento y FechaSiguienteEvento. Usada para mostrar el tiempo de caída directamente en tablas y Gantt.
	column DuracionHHMMSS = ```
			
			VAR Inicio =
			    'repo uptime_bdd_events'[hora_evento]
			
			VAR Fin =
			    'repo uptime_bdd_events'[FechaFin_Gantt_Mes]
			
			VAR SegundosTotales =
			    DATEDIFF( Inicio, Fin, SECOND )
			
			VAR Horas =
			    INT( SegundosTotales / 3600 )
			
			VAR Minutos =
			    INT( MOD( SegundosTotales, 3600 ) / 60 )
			
			VAR Segundos =
			    MOD( SegundosTotales, 60 )
			
			RETURN
			IF(
			    ISBLANK(Fin) || Fin <= Inicio,
			    BLANK(),
			    FORMAT(Horas, "0")
			        & ":" &
			        FORMAT(Minutos, "00")
			        & ":" &
			        FORMAT(Segundos, "00")
			)
			
			
			
			```
		dataType: string
		lineageTag: 697e8eb4-aa7f-4462-ba8f-24a29e344a14
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	/// Etiqueta de texto con el estado del evento: 'DOWN' si arriba=0, 'UP' si arriba=1. Usada en visualizaciones de historial de eventos.
	column Estado = ```
			
			IF('repo uptime_bdd_events'[arriba] = 1, "Arriba", "Abajo")
			
			```
		lineageTag: befb7338-39f3-4514-9980-17b5900de625
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Fecha de fin del evento para el diagrama Gantt: equivale a FechaSiguienteEvento o al momento actual si el evento sigue activo (sin siguiente evento registrado).
	column FechaFin_Gantt = ```
			
			VAR FechaSig = 'repo uptime_bdd_events'[FechaSiguienteEvento]
			VAR LastCheck =
			    CALCULATE(
			        MAX('repo uptime_bdd_current'[last_check]),
			        FILTER(
			            'repo uptime_bdd_current',
			            'repo uptime_bdd_current'[sid]
			                = 'repo uptime_bdd_events'[sid]
			        )
			    )
			RETURN
			COALESCE( FechaSig, LastCheck )
			
			```
		formatString: General Date
		lineageTag: 80fe13f7-7a5d-46d7-a068-83df57260380
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Duración del evento expresada en horas decimales, calculada entre hora_evento y FechaFin_Gantt. Complementa DuracionHHMMSS para cálculos numéricos.
	column DuraHoras = ```
			
			VAR Inicio = 'repo uptime_bdd_events'[hora_evento]
			VAR Fin    = 'repo uptime_bdd_events'[FechaFin_Gantt]
			RETURN
			IF(
			    NOT ISBLANK(Fin) && Fin > Inicio,
			    DATEDIFF( Inicio, Fin, MINUTE ) / 60,
			    0
			)
			
			
			```
		lineageTag: 2c693fd4-604d-41c8-8eeb-264e6a540ee8
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

