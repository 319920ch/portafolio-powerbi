	/// Etiqueta de texto que indica el estado actual de la base de datos: 'UP' si arriba=1, 'DOWN' si arriba=0. Usada en visualizaciones de estado actual.
	column Actual = ```
			
			IF('repo uptime_bdd_current'[arriba] = 1, "Arriba", "Abajo")
			
			```
