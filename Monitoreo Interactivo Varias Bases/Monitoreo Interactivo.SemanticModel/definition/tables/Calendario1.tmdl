	/// Indicador (1/0) que marca si el día es el último del mes. Útil para filtrar cierres de mes en informes mensuales.
	column EsFinDeMes
		formatString: 0
		lineageTag: c151385d-1980-4efb-b90a-efe2850cb598
		summarizeBy: sum
		isNameInferred
		sourceColumn: [EsFinDeMes]

		annotation SummarizationSetBy = Automatic

	/// Indicador (1/0) que marca si el día es el primero del mes. Útil para filtrar aperturas de mes en informes mensuales.
	column EsInicioDeMes
		formatString: 0
		lineageTag: 7668e03e-f152-4221-abad-e71caaf474eb
		summarizeBy: sum
		isNameInferred
		sourceColumn: [EsInicioDeMes]

		annotation SummarizationSetBy = Automatic

	/// Indicador (1/0) que marca si el día es domingo. Útil para excluir fines de semana en cálculos de disponibilidad laboral.
	column EsDomingo
		formatString: 0
		lineageTag: 6090331c-4dd7-4ec1-9432-f4f2687b23a0
		summarizeBy: sum
		isNameInferred
		sourceColumn: [EsDomingo]

		annotation SummarizationSetBy = Automatic

	partition Calendario1 = calculated
		mode: import
		source = ```
				
				VAR FechaInicio =
				    DATE(2020, 1, 1)   -- ajusta según tu histórico real
				VAR FechaFin =
				    DATE(2030, 12, 31) -- o usa varios años
				RETURN
				ADDCOLUMNS(
				    CALENDAR(FechaInicio, FechaFin),
				
				    -- Fecha base
				    "Fecha", [Date],
				
				    -- Año
				    "Año", YEAR([Date]),
				
				    -- Mes (número)
				    "MesNum", MONTH([Date]),
				
				    -- Mes (nombre)
				    "Mes",
				        VAR m = FORMAT ( [Date], "MMMM", "es-ES" )
				        RETURN
				            UPPER ( LEFT ( m, 1 ) ) &
				            MID ( m, 2, LEN ( m ) -1) ,
				
				    -- Año-Mes (clave visual)
				    "AñoMes", FORMAT([Date], "YYYY-MM"),
				
				    -- AñoMes ordenable
				    "AñoMesOrden", YEAR([Date]) * 100 + MONTH([Date]),
				
				    -- Día del mes
				    "DiaMes", DAY([Date]),
				
				    -- Día de la semana (nombre)
				    "DiaSemana", FORMAT([Date], "dddd"),
				
				    -- Día de la semana (número, lunes=1)
				    "DiaSemanaNum", WEEKDAY([Date], 2),
				
				    -- Fin de mes
				    "EsFinDeMes", IF([Date] = EOMONTH([Date], 0), 1, 0),
				
				    -- Inicio de mes
				    "EsInicioDeMes", IF(DAY([Date]) = 1, 1, 0), 
				    
				    "EsDomingo", IF (WEEKDAY ([Date], 2 ) = 7, 1, 0)
				
				
				)
				
				```

	annotation PBI_Id = a0d6521226874a2a8d25fa8e7d53c46f

