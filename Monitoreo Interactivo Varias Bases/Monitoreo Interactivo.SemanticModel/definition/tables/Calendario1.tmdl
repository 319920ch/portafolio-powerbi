	/// Número del día de la semana (1=Domingo o Lunes según configuración). Usado para ordenar correctamente la columna DiaSemana.
	column DiaSemanaNum
		formatString: 0
		lineageTag: 20c3e077-db09-499f-bf22-14c5d6b069ae
		summarizeBy: sum
		isNameInferred
		sourceColumn: [DiaSemanaNum]

