table fichasgest_ficha
	lineageTag: ad839947-45b3-4547-a330-f16e9327da5e

	/// Suma total de horas debitadas (descontadas del contrato) en el período filtrado. Base principal de consumo de horas.
	measure 'Horas Usadas' =
			
			SUM('fichasgest_ficha'[horas_debitadas])
		formatString: 0.00
		lineageTag: 0ee38145-9d11-466f-a64e-984bd42a9779

	/// Diferencia entre horas contratadas y horas usadas. Indica el saldo de horas disponibles en el contrato.
	measure 'Horas Restantes' =
			
			[Horas Contratadas] - [Horas Usadas]
		formatString: 0.00
		lineageTag: 0921eb44-0837-40ac-a0a5-9fd1590976ca

	/// Porcentaje de consumo de horas respecto al total contratado (Horas Usadas / Horas Contratadas). Retorna 0 si no hay horas contratadas.
	measure '% Consumo' =
			
			DIVIDE([Horas Usadas], [Horas Contratadas],0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 7a957d74-3ac0-4e9f-8e90-8789628fc75b

	/// Suma de horas debitadas filtrando solo contratos con Estado Contrato = 'Vigente'. Útil para excluir consumo de contratos vencidos del análisis.
	measure 'Horas Contratadas (Activas - Hoy)' =
			
			CALCULATE(
			    SUM(fichasgest_ficha[horas_debitadas]),
			    KEEPFILTERS(fichasgest_contrato[Estado Contrato] = "Vigente")
			)
		lineageTag: 706b46fb-fc2b-4950-8639-915375363f03

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Suma de horas debitadas cruzando fichas con sus productos asociados mediante TREATAS sobre fichasgest_ficha_productos. Permite analizar el consumo de horas desglosado por producto de soporte.
	measure 'Horas por Producto y Contrato' =
			
			CALCULATE (
			    SUM ( fichasgest_ficha[horas_debitadas] ),
			    TREATAS (
			        VALUES ( fichasgest_ficha_productos[ficha_id] ),
			        fichasgest_ficha[id]
			    )
			)
		lineageTag: d6193b5d-e64d-4f7e-8472-ad3bef3dafe5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Identificador único de la ficha de actividad.
	column id
