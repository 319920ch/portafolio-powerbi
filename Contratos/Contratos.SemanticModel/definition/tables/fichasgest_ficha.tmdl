		sourceColumn: tipo_ficha

		annotation SummarizationSetBy = Automatic

	/// Descripción del detalle de horas trabajadas en la actividad.
	column detalleHoras
		dataType: string
		lineageTag: d4d00a8e-497a-4c30-93d0-7cf7b0fd7226
		summarizeBy: none
		sourceColumn: detalleHoras

		annotation SummarizationSetBy = Automatic

	/// Tipo de soporte prestado en la actividad (ej: remoto, presencial).
	column tipoSoporte
		dataType: string
		lineageTag: 2d5cd9d7-c90f-449c-92b1-fb70a202ea4a
		summarizeBy: none
		sourceColumn: tipoSoporte

		annotation SummarizationSetBy = Automatic

	/// Clave foránea hacia fichasgest_cliente. Cliente al que pertenece la ficha.
	column cliente_id
		dataType: int64
		formatString: 0
		lineageTag: 6d559903-2c52-4c60-8218-efcc6f06126d
		summarizeBy: sum
		sourceColumn: cliente_id

		annotation SummarizationSetBy = Automatic

	/// Clave foránea hacia fichasgest_contrato. Contrato contra el que se debitan las horas.
	column contrato_id
		dataType: int64
		formatString: 0
		lineageTag: 4e8461e6-4e09-4dc0-885e-a9b72f2f0aa1
		summarizeBy: none
		sourceColumn: contrato_id

