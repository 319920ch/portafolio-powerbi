		formatString: 0
		lineageTag: 65e40b26-5d23-481b-b3c2-fd5bb3134def
		summarizeBy: none
		sourceColumn: id

		annotation SummarizationSetBy = Automatic

	/// Horas efectivamente trabajadas en la actividad antes de aplicar debitación.
	column horas_utilizadas
		dataType: double
		lineageTag: 8e43d672-6796-4d5b-9ef3-54eb13e0988e
		summarizeBy: sum
		sourceColumn: horas_utilizadas

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Horas pendientes de debitar al contrato por esta ficha.
	column horas_a_debitar
		dataType: double
		lineageTag: 37e42d26-3e46-4391-be07-0c81571e0cca
		summarizeBy: sum
		sourceColumn: horas_a_debitar

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Horas ya descontadas del contrato por esta ficha. Base de la medida [Horas Usadas].
	column horas_debitadas
		dataType: double
		lineageTag: 3111c136-28eb-4f94-8669-f05fd0d9fc47
		summarizeBy: sum
		sourceColumn: horas_debitadas

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Fecha en que se realizó la actividad registrada en la ficha.
	column fecha_actividad
		dataType: dateTime
		formatString: Long Date
		lineageTag: b2a8c10a-96ac-4772-b616-c6f6722732ce
		summarizeBy: none
		sourceColumn: fecha_actividad

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	/// Tipo de ficha de actividad (ej: soporte, proyecto, consultoría).
	column tipo_ficha
		dataType: string
		lineageTag: 9b5cc5d2-f2b3-4276-b7e7-1bc22b19ae3b
