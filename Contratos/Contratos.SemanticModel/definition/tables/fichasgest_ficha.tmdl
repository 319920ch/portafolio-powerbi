	column proyecto_id
		dataType: int64
		formatString: 0
		lineageTag: b3ee2e41-3a0a-4dde-8306-9078e18c7de9
		summarizeBy: sum
		sourceColumn: proyecto_id

		annotation SummarizationSetBy = Automatic

	/// Fecha de la actividad truncada al día (sin hora). Usada para relacionar con Calendario[Fecha].
	column FechaC = DATEVALUE('fichasgest_ficha'[fecha_actividad])
		formatString: General Date
		lineageTag: d5aec1ac-74ae-4609-9594-33e6418c7fe5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Año de la actividad en texto. Usado para agrupaciones anuales en visualizaciones.
	column Año = YEAR(fichasgest_ficha[FechaC])
		dataType: string
		lineageTag: 38b4de47-19b0-47bc-8535-59d164d7575c
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	/// Número de mes de la actividad (1-12). Usado para agrupaciones mensuales.
	column Mes = MONTH(fichasgest_ficha[FechaC])
		formatString: 0
		lineageTag: f5a5ea2d-8486-4382-8625-43c3cdf5c49a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Nombre del mes de la actividad (ej: 'Marzo'). Usado como etiqueta en visualizaciones.
	column 'Mes Nombre' = FORMAT(fichasgest_ficha[FechaC], "MMMM")
		lineageTag: 89537c99-5bdd-4053-b0e2-ed4af744c0b6
		summarizeBy: none
		sortByColumn: Mes

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

