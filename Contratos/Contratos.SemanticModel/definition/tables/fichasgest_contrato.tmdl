table fichasgest_contrato
	lineageTag: a03eaa4b-3707-4531-b037-7482b1dde32a

	/// Suma del total de horas pactadas en los contratos (numero_horas). Base para cálculos de consumo y saldo.
	measure 'Horas Contratadas' =
			
			SUM(fichasgest_contrato[numero_horas])
		formatString: 0.00
		lineageTag: fc4ac708-0fee-490a-9165-facb62058c23

	/// Etiqueta de estado del contrato basada en la columna calculada Dias Restantes: 'Vencido' (<0 días), 'Por vencer' (≤30 días), 'Vigente'. Usada en tarjetas y visualizaciones de estado.
	measure 'Estado Contrato Medida' =
			
			SWITCH(
			    TRUE(),
			    fichasgest_contrato[Dias Restantes] < 0, "Vencido",
			    fichasgest_contrato[Dias Restantes] <= 30, "Por vencer",
			    "Vigente"
			)
		lineageTag: e14c0043-cee9-4311-afc9-a4b70c2f2818

	/// Días restantes desde hoy hasta la fecha máxima de vencimiento del contrato en el contexto actual. Negativo si el contrato está vencido.
	measure 'Dias Restantes' =
			
			DATEDIFF(
			    TODAY(),
			    MAX(fichasgest_contrato[fecha_vencimiento_contrato]),
			    DAY
			)
		formatString: 0
		lineageTag: c288e34f-f417-45b2-8039-70da97dd900e

	/// Horas restantes (Contratadas - Usadas) solo para contratos cuya fecha de vencimiento es mayor o igual a hoy. Retorna BLANK para contratos vencidos, evitando distorsionar totales.
	measure 'Horas Restantes Vigentes' =
			
			VAR FinContrato =
			    MAX(fichasgest_contrato[fecha_vencimiento_contrato])
			
			RETURN
			IF(
			    FinContrato >= TODAY(),
			    [Horas Contratadas] - [Horas Usadas],
			    BLANK()
			)
		lineageTag: b05cf210-b139-4869-b60f-6548659705d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Suma de Horas Restantes Vigentes iterando por cada contrato distinto (SUMX sobre VALUES de id). Garantiza que el total no colapse por contexto de filtro al mostrar múltiples contratos.
	measure 'Horas Vigentes' =
			
			SUMX(
			    VALUES(fichasgest_contrato[id]),
			    [Horas Restantes Vigentes]
			)
		lineageTag: 81321fc9-f58c-4fc1-bbad-7ccbf7103ab7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Identificador único del contrato.
	column id
