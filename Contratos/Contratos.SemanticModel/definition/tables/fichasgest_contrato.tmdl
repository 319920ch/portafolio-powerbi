				    ticketsdb_Database = Origen{[Name="ticketsdb",Kind="Database"]}[Data],
				    public_Schema = ticketsdb_Database{[Name="public",Kind="Schema"]}[Data],
				    fichasgest_contrato_Table = public_Schema{[Name="fichasgest_contrato",Kind="Table"]}[Data]
				in
